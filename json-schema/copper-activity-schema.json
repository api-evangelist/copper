{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/Activity",
  "title": "Activity",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "format": "int64"
    },
    "parent": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer"
        },
        "type": {
          "type": "string",
          "enum": [
            "lead",
            "person",
            "company",
            "opportunity",
            "project",
            "task"
          ]
        }
      }
    },
    "type": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer"
        },
        "category": {
          "type": "string"
        }
      }
    },
    "details": {
      "type": "string"
    },
    "user_id": {
      "type": "integer"
    },
    "activity_date": {
      "type": "integer"
    },
    "old_value": {
      "type": "object",
      "nullable": true
    },
    "new_value": {
      "type": "object",
      "nullable": true
    },
    "date_created": {
      "type": "integer"
    },
    "date_modified": {
      "type": "integer"
    }
  }
}